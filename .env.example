# ====================================================================
# Environment variables for the layoffs analysis pipeline.
#
# SETUP: Copy this file to `.env` and fill in your actual credentials.
#        The `.env` file is gitignored and will NOT be committed.
# ====================================================================

# ---- PostgreSQL connection ----
DB_USER=postgres
DB_PASS=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=layoffs_analysis

# ---- Optional: logging level ----
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO